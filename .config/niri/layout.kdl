layout {
    gaps 12
    center-focused-column "on-overflow"
    default-column-width { proportion 1.0; }

    focus-ring {
        width 2
        active-color "#89b4fa"
        inactive-color "#45475a"
    }

    border {
        width 2
        active-color "#89b4fa"
        inactive-color "#45475a"
    }

    shadow {
        on
        softness 25
        spread 8
        offset x=0 y=8
        color "#00000040"
    }
}
